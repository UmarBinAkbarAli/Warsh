# Local Android development with USB reverse:
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
EXPO_PUBLIC_ENVIRONMENT=development

# Sentry (error tracking) — leave blank to disable locally
EXPO_PUBLIC_SENTRY_DSN=

# Mixpanel analytics — leave blank to disable locally
EXPO_PUBLIC_MIXPANEL_TOKEN=

# Staging:
# EXPO_PUBLIC_API_URL=https://api-staging.warsh.app
# EXPO_PUBLIC_ENVIRONMENT=staging

# Production:
# EXPO_PUBLIC_API_URL=https://api.warsh.app
# EXPO_PUBLIC_ENVIRONMENT=production
