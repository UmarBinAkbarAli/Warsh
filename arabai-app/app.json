{
  "expo": {
    "name": "Warsh",
    "slug": "Warsh",
    "scheme": "arabai",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "platforms": [
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EBD0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.arabai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4EBD0"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#9A8F6A",
          "sounds": []
        }
      ],
      "@sentry/react-native/expo"
    ],
    "extra": {
      "eas": {
        "projectId": "70bb098d-013a-47ab-88d0-890da928d976"
      }
    }
  }
}
