DATABASE_URL="postgresql://user:password@localhost:5432/arabai"
JWT_SECRET="your-secret-key-min-32-chars"

# AI provider: "openai" or "anthropic"
# If AI_PROVIDER is not set, it auto-detects: uses OpenAI if OPENAI_API_KEY is present, else Anthropic.
AI_PROVIDER=""
AI_DAILY_MESSAGE_LIMIT=5

ANTHROPIC_API_KEY=""
AI_MODEL_DEFAULT="claude-haiku-4-5-20251001"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
