  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Sound feminine plural",
        "ar": "جَمْعُ الْمُؤَنَّثِ السَّالِم",
        "ur": "جمع مؤنث سالم"
      },
      "explanation": {
        "en": "Many feminine nouns end with ة. To make the sound feminine plural, remove ة and add ات.\n\nطَالِبَةٌ -> طَالِبَاتٌ\nمُعَلِّمَةٌ -> مُعَلِّمَاتٌ\nمُؤْمِنَةٌ -> مُؤْمِنَاتٌ",
        "ur": "بہت سے مؤنث اسم ة پر ختم ہوتے ہیں۔ جمع مؤنث سالم بنانے کے لیے ة ہٹائیں اور ات لگائیں۔\n\nطَالِبَةٌ -> طَالِبَاتٌ\nمُعَلِّمَةٌ -> مُعَلِّمَاتٌ\nمُؤْمِنَةٌ -> مُؤْمِنَاتٌ"
      }
    },
    {
      "type": "CONTRAST",
      "concept": {
        "en": "One female student / female students",
        "ar": "طَالِبَةٌ / طَالِبَاتٌ",
        "ur": "ایک طالبہ / طالبات"
      },
      "explanation": {
        "en": "طَالِبَةٌ has the feminine ة. When it becomes plural, the ة is replaced by ات: طَالِبَاتٌ.",
        "ur": "طَالِبَةٌ کے آخر میں مؤنث ة ہے۔ جمع بناتے وقت ة کی جگہ ات آتا ہے: طَالِبَاتٌ۔"
      },
