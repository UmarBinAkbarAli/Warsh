  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Verbal sentence — begins with a verb",
        "ar": "الْجُمْلَة الْفِعْلِيَّة — فِعْل سے شروع ہوتی ہے",
        "ur": "فعلي جملہ — فعل سے شروع ہوتی ہے"
      },
      "explanation": {
        "en": "A verbal sentence (جُمْلَة فِعْلِيَّة) ALWAYS begins with a verb. The first word IS the verb. This is the second pillar of Arabic sentence structure.",
        "ur": "فعلی جملہ (جُمْلَة فِعْلِيَّة) ہمیشہ فعل سے شروع ہوتی ہے۔ پہلا لفظ بنفسۃ الفضل فعل ہے۔ یہ عربی جملے کی دوسری ستون ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "ذَهَبَ الرَّجُلُ",
        "ar_plain": "ذهب الرجل",
        "translit": "dhahaba ar-rajulu",
        "en": "The man went",
        "ur": "آدمی گیا"
      },
      "explanation": {
        "en": "ذَهَبَ is a verb meaning 'went'. It comes FIRST. Then comes الرَّجُلُ (the man) — the subject of the verb. Pattern: فِعْل + فَاعِل.",
        "ur": "ذَهَبَ ایک فعل ہے جس کا مطلب ہے 'گیا'۔ یہ پہلے آتا ہے۔ پھر آتا ہے الرَّجُلُ (آدمی) — فعل کا فَاعِل (کنندہ)۔ فارمولا: فِعْل + فَاعِل۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "قَامَ الطَّالِبُ",
        "ar_plain": "قام الطالب",
        "translit": "qaama at-taalibu",
        "en": "The student stood",
        "ur": "طالب علم کھڑا ہوا"
      },
      "explanation": {
        "en": "قَامَ is a verb (stood). It starts the sentence. الطَّالِبُ is the فاعل (subject/doer). فِعْل + فَاعِل.",
        "ur": "قَامَ ایک فعل ہے (کھڑا ہوا)۔ یہ جملے کا آغاز کرتا ہے۔ الطَّالِبُ فَاعِل ہے (کنندہ)۔ فِعْل + فَاعِل۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "قُلْ يَا أَيُّهَا الْكَافِرُونَ",
        "ar_plain": "قل يا أيها الكافرون",
        "translit": "qul yaa ayyuhaa al-kaafiroon",
        "en": "Say, O disbelievers",
        "ur": "کہہ دیجیے، اے کافرو"
      },
      "explanation": {
        "en": "قُلْ is a verb (imperative: say!). It is the FIRST word. This is a verbal sentence. يَا أَيُّهَا الْكَافِرُونَ is the address (vocative).",
        "ur": "قُلْ ایک فعل ہے (امر: کہہ!)۔ یہ پہلا لفظ ہے۔ یہ ایک فعلی جملہ ہے۔ يَا أَيُّهَا الْكَافِرُونَ (اے کافرو) مخاطب ہے۔"
      }
    },
    {
      "type": "GRAMMAR_NOTE",
      "title": {
        "en": "The pattern: فِعْل + فَاعِل",
        "ur": "فارمولا: فِعْل + فَاعِل"
      },
      "body": {
        "en": "A verbal sentence always starts with a verb. The verb comes first, then its subject (فاعل). ذَهَبَ الرَّجُلُ, قَامَ الطَّالِبُ, قُلْ يَا أَيُّهَا الْكَافِرُونَ — all verbal sentences.",
        "ur": "فعلی جملہ ہمیشہ فعل سے شروع ہوتی ہے۔ فعل پہلے آتا ہے، پھر اس کا فَاعِل (کنندہ)۔ ذَهَبَ الرَّجُلُ، قَامَ الطَّالِبُ، قُلْ يَا أَيُّهَا الْكَافِرُونَ — سب فعلی جملے ہیں۔"
      }
    },
