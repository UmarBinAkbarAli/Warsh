generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
}

model User {
    id             String            @id @default(cuid())
    email          String            @unique
    passwordHash   String
    name           String
    nativeLanguage String            @default("ur")
    translationLanguage String       @default("ur")
    goal           Goal              @default(QURAN)
    level          Level             @default(BEGINNER)
    startingChapterOrder Int?
    placementType  String?
    xp             Int               @default(0)
    gems           Int               @default(0)
    dailyGoalMinutes Int             @default(10)
    trialStartAt   DateTime          @default(now())
    trialExpiresAt DateTime          @default(dbgenerated("now() + interval '7 days'"))
    subscriptionStatus String        @default("trial")
    subscriptionProductId String?
    subscriptionActiveUntil DateTime?
    lastPurchaseToken String?         @unique
    noorOverageBalance Int           @default(0)
    phrasesSpoken  Int               @default(0)
    ttsUsageCount   Int              @default(0)
    ttsUsageResetAt DateTime?
    createdAt      DateTime          @default(now())
    updatedAt      DateTime          @updatedAt
    streak         Streak?
    progress       Progress[]
    chatMessages   ChatMessage[]
    achievements   UserAchievement[]
    userWords          UserVocabularyWord[]
    userSurahProgress  UserSurahProgress[]
}

enum Goal {
    QURAN
    TRAVEL
    STUDY
    GENERAL
}

enum Level {
    BEGINNER
    ELEMENTARY
    INTERMEDIATE
}

model Streak {
    id                String    @id @default(cuid())
    userId            String    @unique
    user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    currentStreak     Int       @default(0)
    longestStreak     Int       @default(0)
    lastActiveDate    DateTime?
    streakFreezes     Int       @default(0)
    lastFreezeUsedAt  DateTime?
    updatedAt         DateTime  @updatedAt
}

model Chapter {
    id          String   @id @default(cuid())
    order       Int      @unique
    title       String
    titleUr     String?
    titleAr     String
    description String
    descriptionUr String?
    worldMapX   Float
    worldMapY   Float
    imageUrl    String?
    isLocked    Boolean  @default(true)
    lessons     Lesson[]
}

model Lesson {
    id          String         @id @default(cuid())
    chapterId   String
    chapter     Chapter        @relation(fields: [chapterId], references: [id])
    order       Int
    title       String
    titleUr     String?
    titleAr     String
    template    LessonTemplate
    xpReward    Int            @default(10)
    content     Json
    updatedAt   DateTime       @default(now()) @updatedAt
    progress    Progress[]
}

enum LessonTemplate {
    STANDARD
    SPOKEN_PHRASES
    REVIEW
    VERB_PATTERN
}

model Progress {
    id          String    @id @default(cuid())
    userId      String
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    lessonId    String
    lesson      Lesson    @relation(fields: [lessonId], references: [id])
    completed   Boolean   @default(false)
    status      String    @default("NOT_STARTED")
    score       Int?
    attempts    Int       @default(0)
    xpEarned    Int       @default(0)
    completedAt DateTime?
    createdAt   DateTime  @default(now())

    @@unique([userId, lessonId])
}

model ChatMessage {
    id        String      @id @default(cuid())
    userId    String
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    role      MessageRole
    content   String
    tokens    Int?
    createdAt DateTime    @default(now())
}

enum MessageRole {
    USER
    ASSISTANT
}

model Achievement {
    id          String            @id @default(cuid())
    key         String            @unique
    title       String
    description String
    icon        String
    xpReward    Int
    users       UserAchievement[]
}

model UserAchievement {
    id            String      @id @default(cuid())
    userId        String
    user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    achievementId String
    achievement   Achievement @relation(fields: [achievementId], references: [id])
    unlockedAt    DateTime    @default(now())

    @@unique([userId, achievementId])
}

model VocabularyWord {
    id               String   @id @default(cuid())
    arabic           String
    arabicPlain      String
    transliteration  String
    translationEn    String
    translationUr    String
    wordType         String
    gender           String?
    pluralForm       String?
    rootLetters      String?
    topicCategories  String[]
    chapterIntroduced Int     @default(1)
    frequencyInQuran  Int?
    quranicExample   Json?
    audioUrl         String?
    imageUrl         String?
    sortOrder        Int      @default(0)
    createdAt        DateTime @default(now())
    userWords        UserVocabularyWord[]
}

model TadabburSurah {
    id          String              @id @default(cuid())
    orderInProg Int                 @unique
    surahNumber Int                 @unique
    nameAr      String
    nameEn      String
    meaningEn   String
    totalAyat   Int
    // JSON: Array<{ ayahNumber, arabic, translationEn, words: Array<{ pos, arabic, arabicPlain, vocabId: string|null }> }>
    ayatData    Json
    createdAt   DateTime            @default(now())
    userProgress UserSurahProgress[]
}

model UserSurahProgress {
    id          String        @id @default(cuid())
    userId      String
    user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    surahId     String
    surah       TadabburSurah @relation(fields: [surahId], references: [id])
    completedAt DateTime?
    updatedAt   DateTime      @updatedAt

    @@unique([userId, surahId])
}

model UserVocabularyWord {
    id                String         @id @default(cuid())
    userId            String
    user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    wordId            String
    word              VocabularyWord @relation(fields: [wordId], references: [id])
    easeFactor        Float          @default(2.5)
    intervalDays      Int            @default(1)
    repetitions       Int            @default(0)
    nextReviewDate    DateTime       @default(now())
    lastReviewQuality Int            @default(0)
    isFavorite        Boolean        @default(false)
    isHidden          Boolean        @default(false)
    createdAt         DateTime       @default(now())
    updatedAt         DateTime       @updatedAt

    @@unique([userId, wordId])
}
