      "concept": {
        "en": "In + it masculine",
        "ar": "فِي + هِ",
        "ur": "میں + وہ مذکر"
      },
      "explanation": {
        "en": "فِي means in. Add the masculine attached pronoun هِ and it becomes فِيهِ: in it.",
        "ur": "فِي کا مطلب ہے میں۔ اس کے ساتھ مذکر ضمیر هِ لگے تو فِيهِ بنتا ہے: اس میں۔"
      }
    },
    {
      "type": "WORD",
      "text": {
        "ar": "فِيهِ",
        "ar_plain": "فيه",
        "translit": "fihi",
        "en": "in it",
        "ur": "اس میں"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "الْقَلَمُ فِي الدَّرْجِ",
        "ar_plain": "القلم في الدرج",
        "translit": "al-qalamu fi ad-darji",
        "en": "The pen is in the drawer",
        "ur": "قلم دراز میں ہے"
      },
      "explanation": {
        "en": "الدَّرْجِ is treated as masculine here, so the next sentence can say فِيهِ.",
        "ur": "الدَّرْجِ یہاں مذکر سمجھا جاتا ہے، اس لیے اگلے جملے میں فِيهِ آ سکتا ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "هُوَ فِيهِ",
        "ar_plain": "هو فيه",
        "translit": "huwa fihi",
        "en": "It is in it",
        "ur": "وہ اس میں ہے"
      },
      "explanation": {
        "en": "فِيهِ points back to a masculine place or thing.",
        "ur": "فِيهِ پچھلی مذکر جگہ یا چیز کی طرف واپس اشارہ کرتا ہے۔"
      }
    }
