  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Sound masculine plural",
        "ar": "جَمْعُ الْمُذَكَّرِ السَّالِم",
        "ur": "جمع مذکر سالم"
      },
      "explanation": {
        "en": "For many masculine people words, Arabic can make the plural by adding ونَ. The base word stays sound: كَاتِبٌ becomes كَاتِبُونَ.",
        "ur": "بہت سے مذکر انسانوں کے الفاظ میں عربی آخر میں ونَ لگا کر جمع بناتی ہے۔ اصل لفظ سالم رہتا ہے: كَاتِبٌ سے كَاتِبُونَ بنتا ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "كَاتِبٌ / كَاتِبُونَ",
        "ar_plain": "كاتب / كاتبون",
        "translit": "kaatibun / kaatiboona",
        "en": "a writer / writers",
        "ur": "ایک لکھنے والا / لکھنے والے"
      },
      "explanation": {
        "en": "كَاتِبٌ means one male writer. Add ونَ and it becomes كَاتِبُونَ: male writers or a mixed group of writers.",
        "ur": "كَاتِبٌ کا مطلب ایک مرد لکھنے والا ہے۔ ونَ لگائیں تو كَاتِبُونَ بنتا ہے: مرد لکھنے والے یا ملا جلا گروہ۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "مُؤْمِنٌ / مُؤْمِنُونَ",
        "ar_plain": "مؤمن / مؤمنون",
        "translit": "mu'minun / mu'minoona",
        "en": "a believer / believers",
        "ur": "ایک مؤمن / مؤمنین"
      },
      "explanation": {
        "en": "The inside of مُؤْمِنٌ does not break or change. The plural ending does the work: مُؤْمِنُونَ.",
        "ur": "مُؤْمِنٌ کی اندرونی شکل نہیں ٹوٹتی اور نہ بدلتی ہے۔ جمع کا کام آخر کا ونَ کرتا ہے: مُؤْمِنُونَ۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "كَافِرٌ / كَافِرُونَ",
        "ar_plain": "كافر / كافرون",
        "translit": "kaafirun / kaafiroona",
        "en": "a disbeliever / disbelievers",
        "ur": "ایک کافر / کافر لوگ"
      },
      "explanation": {
        "en": "In الْكَافِرُونَ, the core word كَافِر remains visible. The ونَ ending tells you it is plural.",
        "ur": "الْكَافِرُونَ میں اصل لفظ كَافِر نظر آتا رہتا ہے۔ آخر کا ونَ بتاتا ہے کہ یہ جمع ہے۔"
      }
    },
    {
      "type": "AYAH_PREVIEW",
      "text": {
        "ar": "الْكَافِرُونَ",
        "ar_plain": "الكافرون",
        "translit": "al-kaafiroona",
        "en": "the disbelievers",
        "ur": "کافر لوگ"
      },
      "explanation": {
        "en": "Surah Al-Kafirun opens with this plural form. Today you are learning to hear and see the ending ونَ.",
        "ur": "سورۃ الکافرون اسی جمع صورت سے شروع ہوتی ہے۔ آج آپ آخر کا ونَ سننا اور دیکھنا سیکھ رہے ہیں۔"
      }
    }
  ],
