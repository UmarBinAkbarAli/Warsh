  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "The three states of المضارع — summary",
        "ar": "حَالَاتُ الْمُضَارِعِ الثَّلَاثُ — مُلَخَّصٌ",
        "ur": "مضارع کی تین حالتیں — خلاصہ"
      },
      "explanation": {
        "en": "Raf' (مرفوع): default state, Dhamma on first letter. Nasb (منصوب): after أَنْ، لَنْ، حَتَّى، فَيْ — Alif at end. Jazm (مجزوم): after لَمْ، لَمَّا، لَا النَّاهِيَة، لام الأمر — vowel dropped from first letter.",
        "ur": "رفع (مرفوع): default حالت، پہلے حرف پر Dhamma۔ نصب (منصوب): أَنْ، لَنْ، حَتَّى، فَيْ کے بعد — آخر میں Alif۔ جزم (مجزوم): لَمْ، لَمَّا، لَا النَّاهِيَة، لام الأمر کے بعد — پہلے حرف سے vowel گرایا جاتا ہے۔"
      }
    },
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Sound masculine plural — three forms",
        "ar": "جَمْعُ الْمُذَكَّرِ السَّالِمُ — ثَلَاثُ صِيَغٍ",
        "ur": "جمع مذکر سالم — تین شکلیں"
      },
      "explanation": {
        "en": "Raf': مُسْلِمُونَ (وُونَ). Nasb/jazm: مُسْلِمِينَ (يَنَ — ن dropped). Idafa: مُسْلِمُو (وُ — ن dropped, no يَنَ ending). The ending tells us the noun's role in the sentence.",
        "ur": "رفع: مُسْلِمُونَ (وُونَ)۔ نصب/جزم: مُسْلِمِينَ (يَنَ — ن ڈرا)۔ اضافت: مُسْلِمُو (وُ — ن ڈرا، كوئی يَنَ ending نہیں)۔ ending ہمیں بتاتی ہے کہ noun کا sentence میں کیا کردار ہے۔"
      }
    },
    {
