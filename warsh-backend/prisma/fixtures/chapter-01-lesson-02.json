  "reveal": {
    "concept_name": {
      "en": "مَا and هَذَا in the Quran — together",
      "ar": "مَا وَهَذَا فِي الْقُرْآن",
      "ur": "قرآن میں مَا اور هَذا ایک ساتھ"
    },
    "ayah": {
      "surah": 2,
      "ayah": 26,
      "label": "Al-Baqarah 2:26",
      "ar": "مَاذَا أَرَادَ اللَّهُ بِهَٰذَا مَثَلًا",
      "en": "What has Allah intended by this example?",
      "ur": "اللہ نے اس مثال سے کیا ارادہ فرمایا؟",
      "audio_url": "https://pub-3da71e4264044cce9d5935f98c79c78c.r2.dev/audio/quran/al-baqarah-026-mishary.mp3"
    },
    "highlighted_word_indices": [
      0,
      2
    ],
    "noor_explanation": {
      "en": "مَاذَا — 'what' — is مَا with ذَا (a short form of هَذَا). And بِهَٰذَا is هَذَا with the preposition بِ — 'with this'. In one short phrase, Allah uses both question words you learned today.",
      "ur": "مَاذَا — یعنی 'کیا' — مَا اور ذَا (هَذا کی مختصر شکل) کا مجموعہ ہے۔ ایک مختصر جملے میں آج کے دونوں الفاظ آ گئے۔"
    }
  },
  "close": {
    "noor_message": {
      "en": "Ten words. You can now say 'This is a teacher', 'Who is that prophet?', 'What is this?' — and you can hear ذٰلِكَ الْكِتَابُ in Al-Baqarah and know exactly what Allah means.",
      "ur": "دس الفاظ۔ اب آپ کہہ سکتے ہیں 'هَذا أُسْتَاذٌ'، 'مَنْ ذٰلِكَ النَّبِيُّ؟'، 'مَا هَذا؟' — اور البقرہ میں ذٰلِکَ الْکِتابُ سمجھ سکتے ہیں۔"
    }
  }
}