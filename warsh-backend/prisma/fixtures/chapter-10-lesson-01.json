    },
    "autoplay": true
  },
  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "They: masculine or mixed",
        "ar": "هُمْ",
        "ur": "وہ سب: مذکر یا مخلوط جماعت"
      },
      "explanation": {
        "en": "هُمْ means they. Use it for a group of males, or for a mixed group.",
        "ur": "هُمْ کا مطلب ہے: وہ سب۔ یہ مذکر جماعت یا مخلوط جماعت کے لیے آتا ہے۔"
      }
    },
    {
      "type": "WORD",
      "text": {
        "ar": "هُمْ طُلَّابٌ",
        "ar_plain": "هم طلاب",
        "translit": "hum tullaabun",
        "en": "They are students",
        "ur": "وہ طلبہ ہیں"
      }
    },
    {
      "type": "CONCEPT",
      "concept": {
        "en": "They: feminine only",
        "ar": "هُنَّ",
        "ur": "وہ سب: صرف مؤنث جماعت"
      },
      "explanation": {
        "en": "هُنَّ means they for a group of females only.",
        "ur": "هُنَّ کا مطلب بھی وہ سب ہے، مگر صرف مؤنث جماعت کے لیے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "هُنَّ طَالِبَاتٌ",
        "ar_plain": "هن طالبات",
