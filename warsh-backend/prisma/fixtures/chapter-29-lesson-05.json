  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Identifying sentence type in Quranic text",
        "ar": "قرآنی متن میں جملے کی قسم کی شناخت",
        "ur": "قرآنی متن میں جملے کی قسم کی شناخت"
      },
      "explanation": {
        "en": "Apply the first-word rule: if the first content word is a verb → verbal sentence; if it is a noun/pronoun → nominal sentence. إِنَّ does NOT change this rule — it still opens a nominal sentence.",
        "ur": "پہلے لفظ کے قاعدے کو لاگو کریں: اگر پہلا اہم لفظ فعل ہے → فعلی جملہ؛ اگر یہ اسم/ضمیر ہے → اسمی جملہ۔ إِنَّ اس قاعدے کو تبدیل نہیں کرتا — یہ پھر بھی ایک اسمی جملہ کھولتا ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "قُلْ يَا أَيُّهَا الْكَافِرُونَ",
        "ar_plain": "قل يا أيها الكافرون",
        "translit": "qul yaa ayyuhaa al-kaafiroon",
        "en": "Say, O disbelievers (verbal — قُلْ is a verb first)",
        "ur": "کہہ دیجیے، اے کافرو (فعلي — قُلْ پہلے فعل ہے)"
      },
      "explanation": {
        "en": "قُلْ is the first word — it is an imperative verb (قول: say!). يَا أَيُّهَا الْكَافِرُونَ is vocative (address). This is a verbal sentence.",
        "ur": "قُلْ پہلا لفظ ہے — یہ ایک امری فعل ہے (کہہ!)۔ يَا أَيُّهَا الْكَافِرُونَ مخاطب ہے۔ یہ ایک فعلی جملہ ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "لَا أَعْبُدُ مَا تَعْبُدُونَ",
        "ar_plain": "لا أعبد ما تعبدون",
        "translit": "laa a'budu maa ta'budoon",
        "en": "I do not worship what you worship (verbal — أَعْبُدُ is a verb first)",
        "ur": "میں اس کی عبادت نہیں کرتا جو تم عبادت کرتے ہو (فعلي — أَعْبُدُ پہلا فعل ہے)"
      },
      "explanation": {
        "en": "أَعْبُدُ is a verb (imperfect, first person) — it is the first content word. لَا is just negation. This is a verbal sentence.",
        "ur": "أَعْبُدُ ایک فعل ہے (مضارع، اول شخص) — یہ پہلا اہم لفظ ہے۔ لَا صرف نفی ہے۔ یہ ایک فعلی جملہ ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "وَلَكُمْ دِينُكُمْ وَلِيَ دِينِ",
        "ar_plain": "ولكم دينكم ولي دين",
        "translit": "wa lakum diinakum wa liya diini",
        "en": "And to you is your religion, and to me is my religion (nominal — وَلَكُمْ starts with pronoun + noun)",
        "ur": "اور تمہارا تمہارا دین ہے اور میرا میرا دین ہے (اسمی — وَلَكُمْ ضمیر + اسم سے شروع ہوتا ہے)"
      },
      "explanation": {
        "en": "وَلَكُمْ starts with وَ (conjunction) + لَكُمْ (pronoun 'to you') + دِينُكُمْ (noun). No verb at the start. This is a nominal sentence.",
        "ur": "وَلَكُمْ وَ (حرف عطف) + لَكُمْ (ضمیر 'تمہارے لیے') + دِينُكُمْ (اسم) سے شروع ہوتا ہے۔ شروع میں کوئی فعل نہیں۔ یہ ایک اسمی جملہ ہے۔"
      }
    },
