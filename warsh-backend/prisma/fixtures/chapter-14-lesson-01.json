    "noor_intro": {
      "en": "الْكَافِرُونَ is a plural noun. When Arabic describes a plural group of people, the adjective matches — it also becomes plural.",
      "ur": "الْكَافِرُونَ ایک جمع اسم ہے۔ جب عربی انسانوں کی جمع کو بیان کرتی ہے تو صفت بھی جمع بنتی ہے۔"
    },
    "autoplay": true
  },
  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Adjective agreement with human plurals",
        "ar": "مُطَابَقَة الصِّفَة لِجَمْعِ الْعَاقِل",
        "ur": "انسانوں کی جمع کے ساتھ صفت کا ملانا"
      },
      "explanation": {
        "en": "When the noun is a plural group of people (human plural), the adjective must also be plural and must match in gender and definiteness.",
        "ur": "جب اسم انسانوں کی جمع ہو، تو صفت بھی جمع ہوتی ہے اور جنس اور تعریف میں ملتی ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "مُسْلِمُونَ كِرَامٌ",
        "ar_plain": "مسلمون كرام",
        "translit": "muslimoona kiraamun",
        "en": "noble Muslims (indefinite)",
        "ur": "شریف مسلمان (نکرہ)"
      },
      "explanation": {
        "en": "مُسْلِمُونَ is the plural noun. كِرَامٌ is the plural adjective 'noble.' Both are indefinite and both are plural.",
        "ur": "مُسْلِمُونَ جمع اسم ہے۔ كِرَامٌ جمع صفت ہے 'شریف'۔ دونوں نکرہ اور جمع ہیں۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "الْمُسْلِمُونَ الْكِرَامُ",
        "ar_plain": "المسلمون الكرام",
        "translit": "al-muslimoona al-kiraamu",
        "en": "the noble Muslims (definite)",
        "ur": "شریف مسلمان (معرفہ)"
      },
      "explanation": {
        "en": "When the noun has ال, the adjective also takes ال. الْمُسْلِمُونَ الْكِرَامُ — both noun and adjective are definite and plural.",
        "ur": "جب اسم پر ال ہو، تو صفت پر بھی ال لگتا ہے۔ الْمُسْلِمُونَ الْكِرَامُ — اسم اور صفت دونوں معرفہ اور جمع ہیں۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "طُلَّابٌ مُجْتَهِدُونَ",
        "ar_plain": "طلاب مجتهدون",
        "translit": "tullaabun mujtahidoona",
        "en": "diligent students",
        "ur": "محنتی طالب علم"
      },
      "explanation": {
        "en": "طُلَّابٌ is a broken plural for students. Its adjective مُجْتَهِدُونَ is still sound masculine plural because the students are people.",
        "ur": "طُلَّابٌ طالب علموں کی کسرہ جمع ہے۔ اس کی صفت مُجْتَهِدُونَ پھر بھی جمع مذکر سالم ہے کیونکہ طالب علم انسان ہیں۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "مُؤْمِنَاتٌ صَالِحَاتٌ",
        "ar_plain": "مؤمنات صالحات",
        "translit": "mu'minaatun saalihaatun",
        "en": "righteous believing women",
        "ur": "نیک مومنہ عورتیں"
      },
      "explanation": {
        "en": "مُؤْمِنَاتٌ is sound feminine plural. The adjective صَالِحَاتٌ also takes the sound feminine plural ending اتٌ to match.",
        "ur": "مُؤْمِنَاتٌ جمع مؤنث سالم ہے۔ صفت صَالِحَاتٌ بھی آخر اتٌ لے کر ملتی ہے۔"
      }
    },
    {
      "type": "GRAMMAR_NOTE",
      "title": {
        "en": "The rule for human plurals",
        "ur": "انسانوں کی جمع کا قاعدہ"
      },
      "body": {
        "en": "People → adjective is plural. Masculine people → adjective ends in ونَ / ينَ. Feminine people → adjective ends in اتٌ / اتٍ.",
        "ur": "انسان → صفت جمع۔ مرد انسان → صفت کا آخر ونَ / ينَ۔ عورت انسان → صفت کا آخر اتٌ / اتٍ۔"
      }
    }
  ],
