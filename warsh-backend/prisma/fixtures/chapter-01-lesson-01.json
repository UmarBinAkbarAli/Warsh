      "text": {
        "ar": "هَذَا",
        "ar_plain": "هذا",
        "translit": "hādhā",
        "en": "this (m)",
        "ur": "یہ (مذکر)"
      },
      "image_url": "https://cdn.warsh.app/images/discover/hadha-pointing.png",
      "audio_url": "https://cdn.warsh.app/audio/vocab/hadha.mp3",
      "explanation": {
        "en": "هَذَا means 'this' when pointing at something masculine and near you. A book, a man, a mosque — anything masculine within reach.",
        "ur": "ہَذَا کا مطلب 'یہ' ہے جب آپ کسی مذکر اور قریب چیز کی طرف اشارہ کرتے ہیں۔"
      },
      "introduces_vocab": {
        "ar_plain": "هذا"
