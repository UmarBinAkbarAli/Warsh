    {
      "type": "WORD",
      "text": {
        "ar": "قَمَر",
        "ar_plain": "قمر",
        "translit": "qamar",
        "en": "moon",
        "ur": "چاند"
      },
      "audio_url": "https://cdn.warsh.app/audio/vocab/qamar.mp3",
      "explanation": {
        "en": "قَمَر — moon. Surah 54 is Al-Qamar. اقْتَرَبَتِ السَّاعَةُ وَانشَقَّ الْقَمَرُ — 'The Hour has drawn near and the moon has split.'",
        "ur": "قَمَر — چاند۔ سورۃ 54 کا نام القمر ہے۔ اقْتَرَبَتِ السَّاعَةُ وَانشَقَّ الْقَمَرُ — 'قیامت قریب آ گئی اور چاند پھٹ گیا'۔"
      },
      "introduces_vocab": {
        "ar_plain": "قمر"
      }
    },
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Arabic doesn't need 'is'",
        "ar": "الْجُمْلَة الْاسْمِيَّة",
        "ur": "عربی میں 'ہے' کی ضرورت نہیں"
      },
      "explanation": {
        "en": "In Arabic, you can say 'This — book' (هَذَا كِتَابٌ) and it means 'This is a book'. The word 'is' is understood without being written. Every noun you just learned can be used this way.",
        "ur": "عربی میں آپ 'یہ کتاب' (هَذا كِتابٌ) کہہ سکتے ہیں اور اس کا مطلب 'یہ ایک کتاب ہے' ہوگا۔ ابھی سیکھے گئے ہر اسم کے ساتھ یہ کام کرتا ہے۔"
      },
      "examples": [
        {
          "ar": "هَذَا كِتَابٌ",
          "ar_plain": "هذا كتاب",
          "translit": "hādhā kitābun",
          "en": "This is a book",
          "ur": "یہ ایک کتاب ہے"
        },
        {
          "ar": "هَذَا نُورٌ",
          "ar_plain": "هذا نور",
          "translit": "hādhā nūrun",
          "en": "This is a light",
          "ur": "یہ ایک روشنی ہے"
        }
      ]
    }
