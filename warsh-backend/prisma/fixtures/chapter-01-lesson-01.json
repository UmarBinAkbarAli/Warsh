      "audio_url": "https://cdn.warsh.app/audio/vocab/kitab.mp3",
      "explanation": {
        "en": "كِتَاب means 'book'. You will see this word often — the Quran refers to itself as الْكِتَاب (the Book).",
        "ur": "کِتاب کا مطلب 'کتاب' ہے۔ قرآن خود کو الْکِتاب کہتا ہے۔"
      },
      "introduces_vocab": {
        "ar_plain": "كتاب"
