    "ayah": {
      "surah": 39,
      "ayah": 53,
      "label": "Az-Zumar 39:53",
      "ar": "قُلْ يَا عِبَادِيَ الَّذِينَ أَسْرَفُوا عَلَىٰ أَنفُسِهِمْ",
      "en": "Say, O My servants who have transgressed against themselves.",
      "ur": "کہہ دیجیے: اے میرے بندو جنہوں نے اپنی جانوں پر زیادتی کی۔",
      "audio_url": "https://pub-3da71e4264044cce9d5935f98c79c78c.r2.dev/audio/quran/az-zumar-053-part-mishary.mp3"
    },
    "noor_intro": {
      "en": "In عِبَادِيَ, the final ي makes the word personal: My servants. Today you learn how Arabic attaches 'my' directly to a noun.",
      "ur": "عِبَادِيَ میں آخر کی ي لفظ کو ذاتی بنا دیتی ہے: میرے بندے۔ آج آپ سیکھیں گے کہ عربی 'میرا' کو اسم کے ساتھ کیسے جوڑتی ہے۔"
    },
    "autoplay": true
  },
  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "My - attached ي",
        "ar": "يَاءُ الْمُتَكَلِّم",
        "ur": "میرا - جڑی ہوئی ي"
      },
      "explanation": {
        "en": "Arabic often expresses 'my' by attaching ي to the end of a noun.\n\nكِتَابٌ - a book\nكِتَابِي - my book\nرَبٌّ - a Lord\nرَبِّي - my Lord\n\nThere is no separate word for 'my' here. The ending carries it.",
        "ur": "عربی میں 'میرا' اکثر اسم کے آخر میں ي لگا کر آتا ہے۔\n\nكِتَابٌ - کتاب\nكِتَابِي - میری کتاب\nرَبٌّ - رب\nرَبِّي - میرا رب\n\nیہاں 'میرا' کے لیے الگ لفظ نہیں آتا۔ آخر کی ي یہ معنی دیتی ہے۔"
      },
