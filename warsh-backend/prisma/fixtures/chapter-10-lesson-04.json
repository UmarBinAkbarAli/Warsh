    "noor_intro": {
      "en": "Some Arabic words arrange events in time. You learned قَبْلَ. Today: بَعْدَ, after.",
      "ur": "کچھ عربی الفاظ واقعات کو وقت میں ترتیب دیتے ہیں۔ آپ نے قَبْلَ سیکھا۔ آج: بَعْدَ، بعد۔"
    },
    "autoplay": true
  },
  "discover_cards": [
    {
      "type": "WORD",
      "text": {
        "ar": "بَعْدَ",
        "ar_plain": "بعد",
        "translit": "ba'da",
        "en": "after",
        "ur": "بعد"
      },
      "explanation": {
        "en": "بَعْدَ means after. It also needs a noun after it.",
        "ur": "بَعْدَ کا مطلب ہے بعد۔ اس کے بعد بھی ایک اسم آتا ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "بَعْدَ الدَّرْسِ",
        "ar_plain": "بعد الدرس",
        "translit": "ba'da ad-darsi",
        "en": "after the lesson",
        "ur": "سبق کے بعد"
      },
      "explanation": {
        "en": "الدَّرْسِ has kasra after بَعْدَ, just like after قَبْلَ.",
        "ur": "بَعْدَ کے بعد الدَّرْسِ کسرہ کے ساتھ آتا ہے، جیسے قَبْلَ کے بعد۔"
      }
    },
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Before and after",
        "ar": "قَبْلَ وَبَعْدَ",
        "ur": "پہلے اور بعد"
      },
      "explanation": {
        "en": "قَبْلَ points backward in sequence. بَعْدَ points forward in sequence.",
        "ur": "قَبْلَ ترتیب میں پہلے کی طرف اشارہ کرتا ہے۔ بَعْدَ بعد کی طرف۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "جَاءُوا بَعْدَ الصَّلَاةِ",
        "ar_plain": "جاءوا بعد الصلاة",
        "translit": "jaa'u ba'da as-salaati",
        "en": "They came after the prayer",
        "ur": "وہ نماز کے بعد آئے"
      },
      "explanation": {
        "en": "بَعْدَ الصَّلَاةِ answers when they came.",
        "ur": "بَعْدَ الصَّلَاةِ بتاتا ہے کہ وہ کب آئے۔"
      }
    }
