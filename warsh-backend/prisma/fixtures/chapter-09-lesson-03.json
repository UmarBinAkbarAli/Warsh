    {
      "type": "CONTRAST",
      "concept": {
        "en": "Regular ending vs changed inside",
        "ar": "جَمْع سَالِم وَجَمْع مُكَسَّر",
        "ur": "سالم جمع اور جمع مکسر"
      },
      "explanation": {
        "en": "مُسْلِمُونَ has a clear ون ending. طَالِبٌ to طُلَّابٌ does not add ون; the word changes inside. That is why it is called broken plural.",
        "ur": "مُسْلِمُونَ میں ون کی صاف علامت ہے۔ طَالِبٌ سے طُلَّابٌ میں ون نہیں لگتا، بلکہ لفظ اندر سے بدلتا ہے۔ اسی لیے اسے جمع مکسر کہتے ہیں۔"
      },
      "examples": [
        {
          "ar": "مُسْلِمٌ / مُسْلِمُونَ",
          "ar_plain": "مسلم مسلمون",
          "translit": "muslimun / muslimuna",
          "en": "a Muslim / Muslims",
          "ur": "ایک مسلمان / مسلمان"
