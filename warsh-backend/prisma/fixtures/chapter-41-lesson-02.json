  "discover_cards": [
    {
      "type": "CONCEPT",
      "concept": {
        "en": "Descriptions of people",
        "ar": "الْأَوْصَافُ الْبَشَرِيَّة",
        "ur": "لوگوں کی تفصیلیں"
      },
      "explanation": {
        "en": "When describing people, Arabic uses the adjective agreement rules you learned: human plural gets plural adjective.",
        "ur": "لوگوں کی تفصیل کرتے وقت عربی وہی صفت کے قاعدے استعمال کرتی ہے جو آپ نے سیکھے: انسانی جمع کو جمع صفت ملتی ہے۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "الْمُؤْمِنُونَ الصَّادِقُونَ",
        "ar_plain": "المؤمنون الصادقون",
        "translit": "al-mu'minoona as-saadiqoona",
        "en": "the sincere believers",
        "ur": "سچے مومنین"
      },
      "explanation": {
        "en": "Human plural noun الْمُؤْمِنُونَ with definite plural adjective الصَّادِقُونَ — both ال and ونَ together.",
        "ur": "انسانی جمع اسم الْمُؤْمِنُونَ کے ساتھ معرفہ جمع صفت الصَّادِقُونَ — ال اور ونَ دونوں ایک ساتھ۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "الْمَرْأَةُ الصَّالِحَةُ",
        "ar_plain": "المرأة الصالحة",
        "translit": "al-mar'atu as-saalihatu",
        "en": "the virtuous woman",
        "ur": "نیک عورت"
      },
      "explanation": {
        "en": "Singular feminine: صَالِحَةُ matches الْمَرْأَةُ in gender, definiteness, and case.",
        "ur": "واحد مؤنث: صَالِحَةُ میں الْمَرْأَةُ کے ساتھ جنس، تعریف اور حکم میں ملتی ہے۔"
      }
    },
    {
      "type": "GRAMMAR_NOTE",
      "title": {
        "en": "Definite adjective rule",
        "ur": "معرفہ صفت کا قاعدہ"
      },
      "body": {
        "en": "When a noun has ال, its adjective must also have ال. When a noun is indefinite, its adjective is also indefinite. Match in number, gender, case, and definiteness.",
        "ur": "جب اسم پر ال ہو، تو اس کی صفت پر بھی ال ہونا چاہیے۔ جب اسم نکرہ ہو، تو صفت بھی نکرہ ہوتی ہے۔ تعداد، جنس، حکم اور تعریف میں ملانا۔"
      }
    },
    {
      "type": "EXAMPLE",
      "text": {
        "ar": "بَيْتٌ كَبِيرٌ",
        "ar_plain": "بيت كبير",
        "translit": "baytun kabirun",
        "en": "a big house",
        "ur": "ایک بڑا گھر"
      },
      "explanation": {
        "en": "Non-human singular: بَيْتٌ (indefinite) with كَبِيرٌ (indefinite). Both agree in indefiniteness.",
        "ur": "غیر انسانی واحد: بَيْتٌ (نکرہ) کے ساتھ كَبِيرٌ (نکرہ)۔ دونوں نکرہ ہونے میں ملتے ہیں۔"
      }
    },
    {
      "type": "WORD",
      "text": {
        "ar": "صَادِقٌ",
        "ar_plain": "صادق",
        "translit": "saadiqun",
        "en": "sincere / truthful",
        "ur": "سچا"
      },
      "explanation": {
        "en": "صَادِقٌ appears in the Quran in context of sincere believers. Root ص-د-ق.",
        "ur": "صَادِقٌ قرآن میں سچے مومنین کے سياق میں آتا ہے۔ مادہ ص-د-ق۔"
      }
    }
  ],
