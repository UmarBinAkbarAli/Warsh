# Local development defaults. Do not commit .env, .env.local, or real secrets.

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warsh_dev"
# DIRECT_DATABASE_URL is required only when using a separate migration URL in hosted environments.
DIRECT_DATABASE_URL=""

# Auth
JWT_SECRET="replace-with-a-random-string-at-least-32-characters"
JWT_EXPIRES_IN="30d"

# Feature flags
DEV_UNLOCK_ALL=false

# Noor / AI
AI_DAILY_MESSAGE_LIMIT=5
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="tts-1"
OPENAI_TTS_VOICE="onyx"

# Cloudflare R2 assets. Required before beta content uses remote audio/images.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="warsh-assets"
R2_PUBLIC_URL="https://assets.warsh.app"
R2_ENDPOINT=""

# Mobile IAP / store integrations. Configure real values only in Vercel/CI secrets.
APPLE_SHARED_SECRET=""
APPLE_BUNDLE_ID="com.warsh.app"
APPLE_NOTIFICATION_WEBHOOK_SECRET=""
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=""
GOOGLE_PLAY_PACKAGE_NAME="com.warsh.app"
GOOGLE_PLAY_NOTIFICATION_WEBHOOK_SECRET=""

# Cron jobs. Set a strong random secret and add it to Vercel environment variables.
CRON_SECRET=""

# Email for password reset (Resend). Get a key at resend.com.
RESEND_API_KEY=""
SMTP_FROM_EMAIL="noreply@warsh.app"

# Legacy SMTP (not used — kept for reference)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# Analytics and errors. Leave blank to disable locally.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
MIXPANEL_TOKEN=""

# Runtime
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="debug"
