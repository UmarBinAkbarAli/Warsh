{
  "name": "warsh-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test tests/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:validate-seed": "node prisma/validate-curriculum.cjs --legacy",
    "db:validate-fixtures": "node prisma/validate-curriculum.cjs --fixtures",
    "db:audit-urdu": "node scripts/audit-urdu-content.cjs",
    "db:studio": "prisma studio",
    "dev:unlock-through": "node scripts/dev-unlock-through.cjs",
    "sentry:smoke": "node scripts/sentry-smoke-test.cjs",
    "images:patch-fixtures": "node scripts/patch-discover-image-urls.cjs",
    "images:patch-fixtures:dry": "node scripts/patch-discover-image-urls.cjs --dry-run",
    "images:compress": "node scripts/compress-images.cjs",
    "images:upload": "npx tsx scripts/upload-vocab-images.ts",
    "images:upload:skip": "npx tsx scripts/upload-vocab-images.ts --skip-existing",
    "images:upload:dry": "npx tsx scripts/upload-vocab-images.ts --dry-run",
    "audio:check": "npx tsx -r dotenv/config scripts/check-audio-count.mjs",
    "audio:prebuild": "npx tsx -r dotenv/config scripts/prebuild-audio-parallel.ts",
    "images:sync-chapters": "npx tsx -r dotenv/config scripts/sync-chapter-images.ts",
    "images:sync-chapters:dry": "npx tsx -r dotenv/config scripts/sync-chapter-images.ts --dry-run"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.53.1",
    "@warsh/lesson-schema": "file:./vendor/lesson-schema",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.0",
    "next": "^14.2.35",
    "openai": "^4.70.0",
    "pg": "^8.20.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "resend": "^6.12.4",
    "tsx": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.14.2",
    "@types/react": "19.2.14",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "prisma": "^7.8.0",
    "sharp": "^0.35.0",
    "typescript": "^5.5.4"
  }
}
